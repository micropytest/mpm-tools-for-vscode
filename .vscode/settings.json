{
  "editor.tabSize": 2,

  "[markdown]": {
    "files.insertFinalNewline": true,
    "editor.formatOnSave": false
  },

  "[json]": {
    "files.insertFinalNewline": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.detectIndentation": false,
    "editor.quickSuggestions": {
      "strings": true
    },
  },

  "[python]": {
    "files.insertFinalNewline": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.detectIndentation": false,
    "editor.insertSpaces": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports": "explicit"
    }
  },

  "ruff.nativeServer": "on",
  "ruff.configuration": ".ruff.toml",
  
  "cSpell.language": "en",
  "cSpell.customDictionaries": {
    "custom-dictionary-workspace": {
      "name": "custom-dictionary-workspace",
      "path": "${workspaceFolder}/.vscode/cspell/custom-dictionary-workspace.txt",
      "addWords": true,
      "scope": "workspace"
    }
  },

  "geminicodeassist.enable": true,
  "geminicodeassist.enableTelemetry": false,
  "geminicodeassist.contextExclusionFile": ".aiexclude",
  "geminicodeassist.contextExclusionGitignore": true,
  "geminicodeassist.inlineSuggestions.enableAuto": false,
  "geminicodeassist.inlineSuggestions.suggestionSpeed": "Slow",

  "chat.agent.enabled": false,
  "chat.disableAIFeatures": true,
  "python-envs.defaultEnvManager": "ms-python.python:system",
  "python-envs.defaultPackageManager": "ms-python.python:pip"
}