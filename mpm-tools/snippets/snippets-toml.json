{
  "Initial content for .ruff.toml": {
    "prefix": ["mpm-ruff"],
    "scope": "toml",
    "include": [".ruff.toml"],
    "body": [
      "target-version = \"py310\"",
      "line-length = 99",
      "indent-width = 2",
      "extend-include = [",
      "  \"${1:${TM_DIRECTORY/.*[\\\\\\/](.*)/$1/}}\",",
      "  \"tests/\",",
      "]",
      "extend-exclude = [",
      "  \"manifest.py\"",
      "]",
      "",
      "[format]",
      "indent-style = \"space\"",
      "docstring-code-format = true",
      "docstring-code-line-length = 99",
      "quote-style = \"double\"",
      "",
      "[lint]",
      "extend-select = [",
      "  \"C9\",",
      "  \"PLC\",",
      "]",
      "extend-ignore = [",
      "  \"E401\",",
      "  \"E402\",",
      "  \"E722\",",
      "  \"E731\",",
      "  \"E741\",",
      "  \"F401\",",
      "  \"F403\",",
      "  \"F405\",",
      "  \"PLC0206\",",
      "  \"PLC0415\",",
      "]",
      "exclude = [ # Ruff finds Python SyntaxError in these files",
      "",
      "]",
      "",
      "[lint.flake8-quotes]",
      "docstring-quotes = \"double\"",
      "",
      "[lint.flake8-type-checking]",
      "strict = true",
      ""
    ]
  },
  "Initial content for pyproject.toml": {
    "prefix": ["mpm-pyproject"],
    "scope": "toml",
    "include": ["pyproject.toml"],
    "body": [
      "[project]",
      "name = \"${1:${TM_DIRECTORY/.*[\\\\\\/](.*)/$1/}}\"",
      "version = \"0.1.0\"",
      "requires-python = \">=3.14\"",
      "dependencies = []",
      "",
      "[tool.poetry]",
      "package-mode = false",
      "",
      "[dependency-groups]",
      "dev = [",
      "\"mpremote (>=1.28.0,<2.0.0)\",",
      "\"pyright (>=1.1.409,<2.0.0)\",",
      "\"ruff (>=0.15.12,<1.0.0)\",",
      "]",
      ""
    ]
  }
}