{
  "Initial content for mpm.json": {
    "prefix": ["mpm-init"],
    "scope": "json",
    "include": ["mpm*.json"],
    "body": [
      "{",
      "  \"v\": \"0.1.0\",",
      "  \"name\": \"${1:${TM_DIRECTORY/.*[\\\\\\/](.*)/$1/}}\",",
      "  \"desc\": \"${2:Description.}\",",
      "  \"license\": \"MIT\",",
      "  \"src\": {",
      "    \"dir\": \"${1:${TM_DIRECTORY/.*[\\\\\\/](.*)/$1/}}\",",
      "    \"include\": [",
      "      \"__init__.py\"",
      "    ],",
      "    \"exclude\": []",
      "  },",
      "  \"deps\": {",
      "    \"lib\": \"deps/lib/\",",
      "    \"prod\": [],",
      "    \"dev\": []",
      "  },",
      "  \"mpmi\": {",
      "    \"indexes\": {",
      "      \"default\": \"github://mpmidev/default\",",
      "      \"micropytest\": \"github://micropytest\"",
      "    }",
      "  },",
      "  \"jobs\": {",
      "    \"build\": {",
      "      \"desc\": \"Prepares the package for its publish.\",",
      "      \"env\": true,",
      "      \"out\": \"cmdln+out\",",
      "      \"params\": {",
      "        \"segment\": {",
      "          \"desc\": \"Version segment to increment: major, minor or patch.\",",
      "          \"type\": \"str\",",
      "          \"value\": \"\"",
      "        }",
      "      },",
      "      \"run\": [",
      "        \"[ -n \\\"{segment}\\\" ] && micropython -m mpm inc-v {segment} || exit 0\",",
      "        \"micropython -m mpm _manifest\",",
      "        \"micropython -m mpm sync\",",
      "        \"micropython -m mpm mpy-cross --from-zero\",",
      "        \"micropython -m mpm mpy --src\"",
      "      ]",
      "    },",
      "    \"tests\": {",
      "      \"desc\": \"Runs the tests.\",",
      "      \"env\": true,",
      "      \"out\": \"out\",",
      "      \"run\": \"micropython -m micropytest run\"",
      "    }",
      "  }",
      "}",
      ""
    ]
  },
  "Initial content for pyrightconfig.json": {
    "prefix": ["mpm-pyright"],
    "scope": "json",
    "include": ["pyrightconfig.json"],
    "body": [
      "{",
      "  \"pythonVersion\": \"3.10\",",
      "  \"pythonPlatform\": \"All\",",
      "  \"include\": [\"${1:${TM_DIRECTORY/.*[\\\\\\/](.*)/$1/}}\", \"tests/\"],",
      "  \"exclude\": [\"**/__pycache__/\", \".git\"],",
      "  \"extraPaths\": [\"deps/typings/\", \"deps/lib/\"],",
      "  \"defineConstant\": {\"TYPE_CHECKING\": true}",
      "}",
      ""
    ]
  }
}
