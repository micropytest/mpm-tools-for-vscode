{
  "Generate the content for .gitignore": {
    "prefix": ["mpm-gitignore"],
    "scope": "ignore",
    "include": [".gitignore"],
    "body": [
      "# dev",
      ".coverage/",
      ".ruff_cache/",
      "/build/",
      "/deps/*",
      "!/deps/typings/",
      "/tests/.reports/",
      "",
      "# cache",
      "__pycache__/",
      "",
      "# env",
      "/.env*",
      ""
    ]
  }
}