{
  "Initial content for .vscode/settings.json": {
    "prefix": ["mpm-vscode-settings"],
    "include": ["settings.json"],
    "body": [
      "{",
      "  \"editor.tabSize\": 2,",
      "  \"[markdown]\": {",
      "    \"files.insertFinalNewline\": true,",
      "    \"editor.formatOnSave\": false",
      "  },",
      "  \"[json]\": {",
      "    \"files.insertFinalNewline\": true,",
      "    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\",",
      "    \"editor.formatOnSave\": true,",
      "    \"editor.detectIndentation\": false,",
      "    \"editor.quickSuggestions\": {",
      "      \"strings\": true",
      "    },",
      "  },",
      "  \"[python]\": {",
      "    \"files.insertFinalNewline\": true,",
      "    \"editor.defaultFormatter\": \"charliermarsh.ruff\",",
      "    \"editor.formatOnSave\": true,",
      "    \"editor.detectIndentation\": false,",
      "    \"editor.insertSpaces\": true,",
      "    \"editor.codeActionsOnSave\": {",
      "      \"source.fixAll.ruff\": \"explicit\",",
      "      \"source.organizeImports\": \"explicit\"",
      "    }",
      "  },",
      "  \"python.testing.pytestEnabled\": false,",
      "  \"python.testing.unittestEnabled\": false,",
      "  \"ruff.nativeServer\": \"on\",",
      "  \"ruff.configuration\": \".ruff.toml\",",
      "  \"cSpell.language\": \"en\",",
      "  \"cSpell.customDictionaries\": {",
      "    \"custom-dictionary-workspace\": {",
      "      \"name\": \"custom-dictionary-workspace\",",
      "      \"path\": \"\\${workspaceFolder}/.vscode/cspell/custom-dictionary-workspace.txt\",",
      "      \"addWords\": true,",
      "      \"scope\": \"workspace\"",
      "    }",
      "  },",
      "  \"geminicodeassist.enable\": true,",
      "  \"geminicodeassist.enableTelemetry\": false,",
      "  \"geminicodeassist.contextExclusionFile\": \".aiexclude\",",
      "  \"geminicodeassist.contextExclusionGitignore\": true,",
      "  \"geminicodeassist.inlineSuggestions.enableAuto\": false,",
      "  \"geminicodeassist.inlineSuggestions.suggestionSpeed\": \"Slow\",",
      "  \"chat.agent.enabled\": false,",
      "  \"chat.disableAIFeatures\": true",
      "}",
      ""
    ]
  }
}